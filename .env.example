# ─────────────────────────────────────────────────────────────────────────────
# Dan — the full tool belt. Copy to `.env` and fill in what you have.
# Dan runs free with NONE of these set; each one arms another capability.
# `.env` is gitignored — secrets are never committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── DATA SOURCES ─────────────────────────────────────────────────────────────
# OpenStreetMap + website scraping need no keys (always on).

# OEM dealer locators (all ~20 brands → brand_confirmed, ~24K coverage).
# Endpoints are bot-protected, so route them through a non-blocked proxy IP.
# Residential/mobile proxy recommended. Format: http://user:pass@host:port
PROXY_URL=

# ── VERIFICATION ─────────────────────────────────────────────────────────────
# Google Places — independent cross-confirm (gold/platinum trust tiers).
# Google Cloud → enable Places API → create key (billing on). Restrict to Places API.
GOOGLE_PLACES_API_KEY=
# PLACES_MAX_ACCOUNTS=200   # cap per run (cost control)

# ── CRM ──────────────────────────────────────────────────────────────────────
# HubSpot (read-only pull). Private App with read scopes.
HUBSPOT_TOKEN=
# HUBSPOT_ALLOW_WRITE=0     # writing back is off by design

# ── CONTACT DATA (paid) ──────────────────────────────────────────────────────
# ZoomInfo REST API — direct dials + verified emails. Credit-safe (dry-run default).
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
# ZOOMINFO_REGIONS=TX,CA,FL
# ZOOMINFO_MAX_ACCOUNTS=50
# ZOOMINFO_APPLY=1          # required to actually spend credits

# Clay — waterfall enrichment.
CLAY_TOKEN=
# CLAY_WEBHOOK_URL=

# ── MISC ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3210
# TARGET_TOTAL=24000        # benchmark target
