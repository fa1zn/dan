# HubSpot READ-ONLY pull (see docs/hubspot-setup.md)
# Create a Private App in HubSpot: Settings → Integrations → Private Apps.
# Grant READ scopes only:
#   crm.objects.companies.read, crm.objects.contacts.read, crm.objects.owners.read
HUBSPOT_TOKEN=

# Writing back to HubSpot is OFF by default. Dan only pulls data in.
# (Leave this unset unless you explicitly want the Dan → HubSpot push path.)
# HUBSPOT_ALLOW_WRITE=0

# ZoomInfo REST API (PAID — see docs/zoominfo-setup.md). Adds direct dials +
# verified emails. Credit-safe: dry-run unless ZOOMINFO_APPLY=1.
ZOOMINFO_USERNAME=
ZOOMINFO_PASSWORD=
# ZOOMINFO_REGIONS=TX,CA,FL
# ZOOMINFO_MAX_ACCOUNTS=50
# ZOOMINFO_MIN_FIT=0
