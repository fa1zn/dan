# HubSpot two-way sync (see docs/hubspot-setup.md)
# Create a Private App in HubSpot: Settings → Integrations → Private Apps.
# Grant scopes: crm.objects.companies.read/write, crm.objects.contacts.read/write,
#               crm.schemas.companies.write, crm.schemas.contacts.write
HUBSPOT_TOKEN=

# Safety switch. Leave unset/0 for a dry run (prints the plan, writes nothing).
# Set to 1 only when you're ready to write to the real HubSpot account.
HUBSPOT_APPLY=0

# Scope of the sync.
HUBSPOT_REGIONS=TX,CA,FL
HUBSPOT_ONLY_ENRICHED=1

# Used for the "Dan Account URL" deep link written onto each HubSpot company.
APP_BASE_URL=http://localhost:3210
